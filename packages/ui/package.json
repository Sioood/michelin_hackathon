{
  "name": "@michelin_hackaton/ui",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build .playground",
    "dev": "nuxt dev .playground",
    "generate": "nuxt generate .playground",
    "preview": "nuxt preview .playground",
    "postinstall": "nuxt prepare && nuxt prepare .playground",
    "lint": "pnpm run lint:oxlint && pnpm run lint:eslint",
    "lint:fix": "pnpm run lint:oxlint --fix && pnpm run lint:eslint --fix",
    "lint:oxlint": "pnpm exec oxlint -c .oxlintrc.json .",
    "lint:eslint": "pnpm exec eslint .",
    "test": "vitest run --project ui-unit --project ui-component",
    "test:coverage": "vitest run --coverage --project ui-unit --project ui-component",
    "test:unit": "vitest run --project ui-unit",
    "test:component": "vitest run --project ui-component",
    "test:visual": "vitest run --project ui-visual",
    "test:watch": "vitest",
    "mutation": "stryker run --incremental",
    "mutation:open": "stryker run --incremental && open reports/stryker-mutation.html",
    "format": "pnpm exec oxfmt --write .",
    "format:check": "pnpm exec oxfmt --check .",
    "i18n:coverage": "pnpm exec michelin_hackaton-i18n-coverage -f ./i18n/locales",
    "i18n:coverage:namespace": "pnpm exec michelin_hackaton-i18n-coverage -f ./i18n/locales --ns"
  },
  "dependencies": {
    "@ark-ui/vue": "catalog:",
    "@internationalized/date": "3.12.0",
    "@michelin_hackaton/nuxt-essentials": "workspace:*",
    "@nuxt/fonts": "0.14.0",
    "@nuxt/icon": "2.2.1",
    "@nuxt/image": "2.0.0",
    "@tailwindcss/vite": "catalog:",
    "@tanstack/form-core": "catalog:",
    "@tanstack/table-core": "catalog:",
    "@tanstack/vue-form": "catalog:",
    "@tanstack/vue-table": "catalog:",
    "@tanstack/vue-virtual": "catalog:",
    "@unovis/ts": "catalog:",
    "@unovis/vue": "catalog:",
    "class-variance-authority": "catalog:",
    "fuse.js": "catalog:",
    "nuxt": "catalog:",
    "tailwind-merge": "catalog:",
    "tailwindcss": "catalog:",
    "v-gsap-nuxt": "1.5.12",
    "vue": "catalog:",
    "vue-router": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@compodium/nuxt": "0.1.0-beta.12",
    "@michelin_hackaton/eslint": "workspace:^",
    "@michelin_hackaton/oxlint": "workspace:^",
    "@nuxt/kit": "catalog:",
    "@nuxt/test-utils": "^4.0.3",
    "@stryker-mutator/api": "^9.6.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/browser": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vue/test-utils": "^2.4.10",
    "@vueuse/core": "catalog:",
    "happy-dom": "^20.9.0",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "playwright": "catalog:",
    "unplugin-auto-import": "^21.0.0",
    "vitest": "catalog:"
  }
}
