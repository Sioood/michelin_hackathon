# =============================================================================
# @michelin_hackaton/ui — Nuxt runtime (NUXT_* / NUXT_PUBLIC_*)
# Copy to `.env` in this package when running the UI layer standalone.
# Inherits @michelin_hackaton/nuxt-essentials; values here override merged `runtimeConfig`.
# =============================================================================

# Overrides `runtimeConfig.public.siteUrl` (SEO, links, public client config).
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# Secret for @nuxtjs/seo / nuxt-og-image signed URLs. Generate with:
#   pnpx nuxt-og-image generate-secret
NUXT_OG_IMAGE_SECRET=
