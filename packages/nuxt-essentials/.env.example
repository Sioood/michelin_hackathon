# =============================================================================
# @michelin_hackaton/nuxt-essentials — Nuxt runtime (NUXT_* / NUXT_PUBLIC_*)
# Copy to `.env` in this package when running `nuxt dev` / `nuxt build` here.
# =============================================================================

# Canonical public site URL (no trailing slash recommended).
# Used by nuxt-security CORS in production (`nuxt.config.ts` → `corsHandler.origin`).
# Must match the browser origin you use in dev (e.g. http://localhost:3000).
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# Secret for @nuxtjs/seo / nuxt-og-image signed URLs. Generate with:
#   pnpx nuxt-og-image generate-secret
NUXT_OG_IMAGE_SECRET=
