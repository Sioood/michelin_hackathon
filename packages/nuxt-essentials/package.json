{
  "name": "@michelin_hackaton/nuxt-essentials",
  "version": "0.0.1",
  "private": true,
  "bin": {
    "michelin_hackaton-i18n-coverage": "./michelin_hackaton-i18n-coverage.mjs"
  },
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "lint": "pnpm run lint:oxlint && pnpm run lint:eslint",
    "lint:fix": "pnpm run lint:oxlint --fix && pnpm run lint:eslint --fix",
    "lint:oxlint": "pnpm exec oxlint -c .oxlintrc.json .",
    "lint:eslint": "pnpm exec eslint .",
    "format": "pnpm exec oxfmt",
    "format:check": "pnpm exec oxfmt --check .",
    "i18n:coverage": "node ./i18n/utils/coverage.ts -f ./i18n/locales",
    "i18n:coverage:namespace": "node ./i18n/utils/coverage.ts -f ./i18n/locales --ns",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "mutation": "stryker run --incremental",
    "mutation:open": "stryker run --incremental && open reports/stryker-mutation.html"
  },
  "dependencies": {
    "@nuxt/eslint": "catalog:",
    "@nuxtjs/i18n": "catalog:",
    "@nuxtjs/seo": "catalog:",
    "@pinia/nuxt": "catalog:",
    "@takumi-rs/core": "^1.4.1",
    "@vite-pwa/nuxt": "catalog:",
    "@vueuse/nuxt": "catalog:",
    "nuxt": "catalog:",
    "nuxt-security": "catalog:",
    "pinia": "catalog:",
    "vue": "catalog:",
    "vue-router": "catalog:"
  },
  "devDependencies": {
    "@michelin_hackaton/eslint": "workspace:^",
    "@michelin_hackaton/oxlint": "workspace:^",
    "@modyfi/vite-plugin-yaml": "^1.1.1",
    "@nuxt/kit": "catalog:",
    "@stryker-mutator/api": "^9.6.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@vitest/coverage-v8": "catalog:",
    "consola": "^3.4.2",
    "es-main": "^1.4.0",
    "minimist": "^1.2.8",
    "vitest": "catalog:",
    "yaml": "catalog:"
  }
}
