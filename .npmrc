link-workspace-packages = true
prefer-workspace-packages = true
recursive-install = true
audit-level = high

# Nuxt layer architecture requires cross-package dep resolution.
# Using targeted hoisting instead of shamefully-hoist=true.
public-hoist-pattern[]=@vue/*
public-hoist-pattern[]=vue
public-hoist-pattern[]=nuxt
public-hoist-pattern[]=@nuxt/*
public-hoist-pattern[]=@nuxtjs/*
public-hoist-pattern[]=@pinia/*
public-hoist-pattern[]=pinia
public-hoist-pattern[]=@vueuse/*
public-hoist-pattern[]=vueuse
public-hoist-pattern[]=@ark-ui/*
public-hoist-pattern[]=@tanstack/*
public-hoist-pattern[]=tailwindcss
public-hoist-pattern[]=tailwind-merge
public-hoist-pattern[]=class-variance-authority
public-hoist-pattern[]=zod
