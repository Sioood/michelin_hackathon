{
  "name": "@michelin_hackaton/api",
  "version": "0.0.1",
  "private": true,
  "description": "",
  "license": "UNLICENSED",
  "author": "",
  "scripts": {
    "build": "nest build",
    "dev": "pnpm run start:dev",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "pnpm run lint:oxlint && pnpm run lint:eslint",
    "lint:fix": "pnpm run lint:oxlint --fix && pnpm run lint:eslint --fix",
    "lint:oxlint": "pnpm exec oxlint -c .oxlintrc.json .",
    "lint:eslint": "pnpm exec eslint .",
    "format": "pnpm exec oxfmt --write .",
    "format:check": "pnpm exec oxfmt --check .",
    "check-types": "tsc --noEmit -p tsconfig.check.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/sequelize": "catalog:",
    "pg": "catalog:",
    "pg-hstore": "catalog:",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sequelize": "catalog:",
    "sequelize-typescript": "catalog:"
  },
  "devDependencies": {
    "@michelin_hackaton/eslint": "workspace:^",
    "@michelin_hackaton/oxlint": "workspace:^",
    "@michelin_hackaton/typescript": "workspace:^",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "catalog:",
    "@types/supertest": "^7.0.0",
    "eslint": "catalog:",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "catalog:"
  },
  "jest": {
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testEnvironment": "node",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.spec.json"
        }
      ]
    }
  }
}
