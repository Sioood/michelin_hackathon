{
  "name": "@michelin_hackaton/web",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "pnpm run lint:oxlint && pnpm run lint:eslint",
    "lint:fix": "pnpm run lint:oxlint --fix && pnpm run lint:eslint --fix",
    "lint:oxlint": "pnpm exec oxlint -c .oxlintrc.json .",
    "lint:eslint": "pnpm exec eslint .",
    "format": "pnpm exec oxfmt --write .",
    "format:check": "pnpm exec oxfmt --check .",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "i18n:coverage": "pnpm exec michelin_hackaton-i18n-coverage -f ./i18n/locales",
    "i18n:coverage:namespace": "pnpm exec michelin_hackaton-i18n-coverage -f ./i18n/locales --ns"
  },
  "dependencies": {
    "@internationalized/date": "catalog:",
    "@michelin_hackaton/nuxt-essentials": "workspace:^",
    "@michelin_hackaton/ui": "workspace:^",
    "@tresjs/core": "catalog:",
    "nuxt": "catalog:",
    "three": "catalog:",
    "vue": "catalog:",
    "vue-router": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@michelin_hackaton/eslint": "workspace:^",
    "@michelin_hackaton/oxlint": "workspace:^",
    "@nuxt/kit": "catalog:",
    "@playwright/test": "catalog:",
    "@types/three": "catalog:",
    "eslint": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:"
  }
}
