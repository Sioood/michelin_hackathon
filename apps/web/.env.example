# =============================================================================
# @michelin_hackaton/web — Nuxt runtime (NUXT_* / NUXT_PUBLIC_*)
# Copy to `apps/web/.env` for local development (`pnpm dev` in this app).
# See: https://nuxt.com/docs/guide/going-further/runtime-config#environment-variables
# =============================================================================

# Public site URL (client + server). Maps to `runtimeConfig.public.siteUrl`.
# Use the same origin as the tab you open (e.g. http://localhost:3000).
NUXT_PUBLIC_SITE_URL=http://localhost:3000
NUXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Secret for @nuxtjs/seo / nuxt-og-image signed URLs. Generate with:
#   pnpx nuxt-og-image generate-secret
NUXT_OG_IMAGE_SECRET=
